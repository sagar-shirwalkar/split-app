# ─── Dependencies ────────────────────────────────────────────
# Installed by `npm install` at the root and each workspace.
# Reproducible from package.json + package-lock.json.
node_modules/

# ─── Build output ────────────────────────────────────────────
# Vite outputs to frontend/dist/; the SDK and seismic-wrapper
# have their own dist/ directories too. `dist` matches any level.
dist/

# The split-app bundle that ships to ServiceNow. Generated by
# scripts/build-frontend.cjs from frontend/dist/, then version-
# stamped with a content hash by the same script.
sn-sdk/src/client/

# Root-level bundle version file (used by build-frontend.cjs
# and build-seismic.cjs to coordinate the hash). Regenerated
# on every build, so a commit of it would always churn.
.split-bundle-version

# ─── Secrets & environment ───────────────────────────────────
# Per-instance credentials (PDI hostnames, dev tokens, etc.).
# Keep the .env.example checked in; ignore the real one.
.env
.env.local
.env.*.local

# ─── Editor / IDE / OS noise ─────────────────────────────────
# Kiro / Kilo agent state
.kilo/
# VSCode workspace state
.vscode/
# JetBrains
.idea/
# macOS Finder metadata
.DS_Store
# Windows thumbnails
Thumbs.db

# ─── ServiceNow SDK artifacts ────────────────────────────────
# target/  — packaged zip output from `now-sdk package`
# .now/    — instance-specific metadata, including bom.json
#            (the bom.json entry below is defensive: even if
#            someone removes the directory rule, the manifest
#            still won't leak)
sn-sdk/target/
sn-sdk/.now/
sn-sdk/.now/bom.json

# ─── Logs & runtime ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Test artifacts ──────────────────────────────────────────
# Add if/when a test framework is introduced
# coverage/
